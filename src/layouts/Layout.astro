---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  canonical?: string;
  ogType?: string;
  ogImage?: string;
  author?: string;
  publishedTime?: string;
  tags?: string[];
  articleSection?: string;
}

const {
  title = 'Dale Hurley - AI-Driven Tech Entrepreneur & Banking Innovation Leader',
  description = 'AI-driven tech entrepreneur, banking innovation leader, and co-founder of Avenue Bank. Expert in fintech solutions, AI automation, and startup development.',
  keywords = 'Dale Hurley, AI entrepreneur, fintech, banking innovation, Avenue Bank, CreditorWatch, AI automation',
  canonical,
  ogType = 'website',
  ogImage,
  author = 'Dale Hurley',
  publishedTime,
  tags = [],
  articleSection,
} = Astro.props;

const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const ogImageURL = ogImage ?? new URL('/images/dale-hurley-og.jpg', Astro.site).toString();
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content={author} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

    <!-- Performance & SEO -->
    <meta name="theme-color" content="#FF750F" />
    <meta name="msapplication-TileColor" content="#FF750F" />
    <meta name="apple-mobile-web-app-capable" content="yes" />

    <!-- Favicon -->
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- RSS Feed -->
    <link rel="alternate" type="application/rss+xml" title="Dale Hurley Blog" href="/rss.xml" />

    <!-- Resource hints -->
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <link rel="dns-prefetch" href="//dalehurley.com" />

    <!-- Security -->
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Dale Hurley" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@dalehurley" />
    <meta name="twitter:creator" content="@dalehurley" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Article meta -->
    {ogType === 'article' && (
      <>
        <meta property="article:author" content={author} />
        {publishedTime && <meta property="article:published_time" content={publishedTime} />}
        {articleSection && <meta property="article:section" content={articleSection} />}
        {tags.map((tag) => <meta property="article:tag" content={tag} />)}
      </>
    )}

    <!-- Default Person JSON-LD -->
    {ogType === 'website' && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Dale Hurley",
        "jobTitle": "AI-Driven Tech Entrepreneur & Banking Innovation Leader",
        "description": description,
        "url": new URL('/', Astro.site).toString(),
        "image": new URL('/images/dale-hurley.jpg', Astro.site).toString(),
        "sameAs": [
          "https://www.linkedin.com/in/dalehurley/",
          "https://github.com/dalehurley",
          "https://twitter.com/dalehurley"
        ],
        "worksFor": [{ "@type": "Organization", "name": "LEAP Legal Software" }],
        "knowsAbout": ["Artificial Intelligence", "Fintech", "Banking Innovation", "Startup Development"],
        "alumniOf": { "@type": "Organization", "name": "CreditorWatch" }
      })} />
    )}

    <slot name="head" />
  </head>

  <body class="bg-white dark:bg-gray-900">
    <!-- Skip to content -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-0 focus:left-0 bg-[#FF750F] text-white px-4 py-2 z-50"
    >
      Skip to main content
    </a>

    <!-- Sticky Header (#2: sticky with backdrop blur) -->
    <header id="site-header" class="sticky top-0 z-50 transition-all duration-300">
      <nav aria-label="Main navigation" class="mx-auto flex max-w-7xl items-center justify-between p-6 lg:px-8">
        <div class="flex lg:flex-1">
          <a href="/" class="-m-1.5 p-1.5" aria-label="Dale Hurley homepage">
            <span class="sr-only">Dale Hurley</span>
            <span class="text-xl font-bold text-[#FF750F]">DaleHurley.com</span>
          </a>
        </div>

        <!-- Desktop nav -->
        <div class="hidden lg:flex lg:gap-x-12" role="navigation">
          <a
            href="/"
            class={`text-sm font-semibold leading-6 transition-colors ${currentPath === '/' ? 'text-[#FF750F]' : 'text-gray-900 dark:text-white hover:text-[#FF750F]'}`}
            aria-current={currentPath === '/' ? 'page' : undefined}
          >Home</a>
          <a
            href="/posts"
            class={`text-sm font-semibold leading-6 transition-colors ${currentPath.startsWith('/posts') ? 'text-[#FF750F]' : 'text-gray-900 dark:text-white hover:text-[#FF750F]'}`}
            aria-current={currentPath.startsWith('/posts') ? 'page' : undefined}
          >Blog</a>
          <a
            href="/principles"
            class={`text-sm font-semibold leading-6 transition-colors ${currentPath === '/principles' ? 'text-[#FF750F]' : 'text-gray-900 dark:text-white hover:text-[#FF750F]'}`}
            aria-current={currentPath === '/principles' ? 'page' : undefined}
          >Principles</a>
          <a
            href="/#track-record"
            class="text-sm font-semibold leading-6 transition-colors text-gray-900 dark:text-white hover:text-[#FF750F]"
          >About</a>
          <a
            href="/#contact"
            class="text-sm font-semibold leading-6 transition-colors text-gray-900 dark:text-white hover:text-[#FF750F]"
          >Contact</a>
        </div>

        <!-- Mobile hamburger button (#1: mobile menu) -->
        <button
          id="mobile-menu-btn"
          class="lg:hidden p-2 rounded-md text-gray-700 dark:text-gray-200 hover:text-[#FF750F] transition-colors"
          aria-label="Open navigation menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg id="hamburger-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </nav>

      <!-- Mobile menu panel (#1: mobile menu) -->
      <div
        id="mobile-menu"
        class="hidden lg:hidden border-t border-gray-200 dark:border-gray-700 bg-white/95 dark:bg-gray-900/95 backdrop-blur-md"
        role="navigation"
        aria-label="Mobile navigation"
      >
        <div class="px-6 py-4 space-y-3">
          <a
            href="/"
            class={`block px-3 py-2 rounded-md text-base font-semibold transition-colors ${currentPath === '/' ? 'text-[#FF750F] bg-orange-50 dark:bg-orange-900/20' : 'text-gray-900 dark:text-white hover:text-[#FF750F] hover:bg-gray-50 dark:hover:bg-gray-800'}`}
            aria-current={currentPath === '/' ? 'page' : undefined}
          >Home</a>
          <a
            href="/posts"
            class={`block px-3 py-2 rounded-md text-base font-semibold transition-colors ${currentPath.startsWith('/posts') ? 'text-[#FF750F] bg-orange-50 dark:bg-orange-900/20' : 'text-gray-900 dark:text-white hover:text-[#FF750F] hover:bg-gray-50 dark:hover:bg-gray-800'}`}
            aria-current={currentPath.startsWith('/posts') ? 'page' : undefined}
          >Blog</a>
          <a
            href="/principles"
            class={`block px-3 py-2 rounded-md text-base font-semibold transition-colors ${currentPath === '/principles' ? 'text-[#FF750F] bg-orange-50 dark:bg-orange-900/20' : 'text-gray-900 dark:text-white hover:text-[#FF750F] hover:bg-gray-50 dark:hover:bg-gray-800'}`}
            aria-current={currentPath === '/principles' ? 'page' : undefined}
          >Principles</a>
          <a
            href="/#track-record"
            class="block px-3 py-2 rounded-md text-base font-semibold text-gray-900 dark:text-white hover:text-[#FF750F] hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors"
          >About</a>
          <a
            href="/#contact"
            class="block px-3 py-2 rounded-md text-base font-semibold text-gray-900 dark:text-white hover:text-[#FF750F] hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors"
          >Contact</a>
        </div>
      </div>
    </header>

    <main id="main-content" role="main">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-gray-800 dark:bg-gray-900">
      <div class="mx-auto max-w-7xl px-6 pt-16 pb-8 sm:pt-24 lg:px-8 lg:pt-32">
        <div class="xl:grid xl:grid-cols-3 xl:gap-8">
          <div class="space-y-8">
            <span class="text-2xl font-bold text-[#FF750F]">DaleHurley.com</span>
            <p class="text-sm/6 text-balance text-gray-300">Building the future with AI and banking innovation</p>
            <div class="flex gap-x-6">
              <!-- Twitter/X -->
              <a href="https://x.com/dalehurley" class="text-gray-400 hover:text-gray-300" aria-label="Twitter">
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84" />
                </svg>
              </a>
              <!-- GitHub -->
              <a href="https://github.com/dalehurley" class="text-gray-400 hover:text-gray-300" aria-label="GitHub">
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                  <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
                </svg>
              </a>
              <!-- LinkedIn -->
              <a href="https://www.linkedin.com/in/dalehurley/" class="text-gray-400 hover:text-gray-300" aria-label="LinkedIn">
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" />
                </svg>
              </a>
              <!-- RSS -->
              <a href="/rss.xml" class="text-gray-400 hover:text-gray-300" aria-label="RSS Feed">
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
                </svg>
              </a>
            </div>
          </div>

          <div class="mt-16 grid grid-cols-2 gap-8 xl:col-span-2 xl:mt-0">
            <div class="md:grid md:grid-cols-2 md:gap-8">
              <div>
                <h3 class="text-sm font-semibold text-white">Solutions</h3>
                <ul class="mt-6 space-y-4">
                  {[
                    { href: '/#ai-solutions', text: 'AI Prototyping' },
                    { href: '/#ai-solutions', text: 'Process Automation' },
                    { href: '/#ai-solutions', text: 'Strategic Innovation' },
                    { href: '/#projects', text: 'Fintech Solutions' },
                  ].map(link => (
                    <li><a href={link.href} class="text-sm text-gray-300 hover:text-white">{link.text}</a></li>
                  ))}
                </ul>
              </div>
              <div class="mt-10 md:mt-0">
                <h3 class="text-sm font-semibold text-white">Connect</h3>
                <ul class="mt-6 space-y-4">
                  {[
                    { href: 'https://www.linkedin.com/in/dalehurley/', text: 'LinkedIn' },
                    { href: 'https://x.com/dalehurley', text: 'Twitter' },
                    { href: 'https://github.com/dalehurley', text: 'GitHub' },
                    { href: '/rss.xml', text: 'RSS Feed' },
                  ].map(link => (
                    <li><a href={link.href} class="text-sm text-gray-300 hover:text-white">{link.text}</a></li>
                  ))}
                </ul>
              </div>
            </div>
            <div class="md:grid md:grid-cols-2 md:gap-8">
              <div>
                <h3 class="text-sm font-semibold text-white">About</h3>
                <ul class="mt-6 space-y-4">
                  {[
                    { href: '/#track-record', text: 'Track Record' },
                    { href: '/#projects', text: 'Projects' },
                    { href: '/posts', text: 'Blog' },
                    { href: '/principles', text: 'Principles' },
                    { href: '/#contact', text: 'Contact' },
                  ].map(link => (
                    <li><a href={link.href} class="text-sm text-gray-300 hover:text-white">{link.text}</a></li>
                  ))}
                </ul>
              </div>
              <div class="mt-10 md:mt-0">
                <h3 class="text-sm font-semibold text-white">Projects</h3>
                <ul class="mt-6 space-y-4">
                  {[
                    { href: 'https://full.cx', text: 'Full.CX' },
                    { href: 'https://doccheetah.com', text: 'DocCheetah' },
                    { href: 'https://spotfillr.com', text: 'Spotfillr' },
                  ].map(link => (
                    <li><a href={link.href} class="text-sm text-gray-300 hover:text-white">{link.text}</a></li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </div>

        <div class="mt-16 border-t border-white/10 pt-8">
          <p class="text-sm/6 text-gray-300 text-center">
            &copy; {new Date().getFullYear()} Dale Hurley. All rights reserved. Made with ❤️ in Australia 🐨 🦘.
          </p>
        </div>
      </div>
    </footer>

    <!-- Back to top button (#4) -->
    <button
      id="back-to-top"
      class="fixed bottom-8 right-8 z-50 p-3 bg-[#FF750F] text-white rounded-full shadow-lg opacity-0 invisible transition-all duration-300 hover:bg-orange-500 hover:scale-110 focus:outline-none focus:ring-2 focus:ring-[#FF750F] focus:ring-offset-2"
      aria-label="Back to top"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
      </svg>
    </button>

    <script>
      // #1: Mobile hamburger menu
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const hamburgerIcon = document.getElementById('hamburger-icon');
      const closeIcon = document.getElementById('close-icon');

      mobileMenuBtn?.addEventListener('click', () => {
        const isOpen = mobileMenu?.classList.contains('hidden') === false;
        if (isOpen) {
          mobileMenu?.classList.add('hidden');
          hamburgerIcon?.classList.remove('hidden');
          closeIcon?.classList.add('hidden');
          mobileMenuBtn.setAttribute('aria-expanded', 'false');
        } else {
          mobileMenu?.classList.remove('hidden');
          hamburgerIcon?.classList.add('hidden');
          closeIcon?.classList.remove('hidden');
          mobileMenuBtn.setAttribute('aria-expanded', 'true');
        }
      });

      // Close mobile menu when a link is clicked
      mobileMenu?.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu.classList.add('hidden');
          hamburgerIcon?.classList.remove('hidden');
          closeIcon?.classList.add('hidden');
          mobileMenuBtn?.setAttribute('aria-expanded', 'false');
        });
      });

      // #2: Sticky header with backdrop blur on scroll
      const header = document.getElementById('site-header');
      const updateHeader = () => {
        if (window.scrollY > 10) {
          header?.classList.add('bg-white/90', 'dark:bg-gray-900/90', 'backdrop-blur-md', 'shadow-sm', 'border-b', 'border-gray-200/50', 'dark:border-gray-700/50');
        } else {
          header?.classList.remove('bg-white/90', 'dark:bg-gray-900/90', 'backdrop-blur-md', 'shadow-sm', 'border-b', 'border-gray-200/50', 'dark:border-gray-700/50');
        }
      };
      window.addEventListener('scroll', updateHeader, { passive: true });
      updateHeader();

      // #4: Back to top button
      const backToTop = document.getElementById('back-to-top');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 400) {
          backToTop?.classList.remove('opacity-0', 'invisible');
          backToTop?.classList.add('opacity-100', 'visible');
        } else {
          backToTop?.classList.add('opacity-0', 'invisible');
          backToTop?.classList.remove('opacity-100', 'visible');
        }
      }, { passive: true });

      backToTop?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });

      // #14: Scroll-triggered fade-in animations
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('animate-in');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });

      document.querySelectorAll('.fade-in-section').forEach(el => observer.observe(el));
    </script>
  </body>
</html>
