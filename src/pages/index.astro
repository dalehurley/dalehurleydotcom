---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const featuredPosts = posts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

// Estimate reading time from raw body (average 200 wpm)
function estimateReadingTime(body: string): number {
  const words = body.trim().split(/\s+/).length;
  return Math.max(1, Math.round(words / 200));
}

const commercialProjects = [
  { name: 'DocCheetah', desc: 'AI-powered document processing and analysis', url: 'https://doccheetah.com/', image: '/images/doc-cheetah-logo.webp' },
  { name: 'Spotfillr', desc: 'Intelligent parking space optimisation', url: 'https://spotfillr.com/', image: '/images/spotfill-logo.webp' },
  { name: 'Full.CX', desc: 'Customer experience enhancement platform', url: 'https://full.cx/', image: '/images/full-cx-logo.webp' },
  { name: 'Custom Homework Maker', desc: 'AI-generated personalised learning materials', url: 'https://customhomeworkmaker.com/', image: '/images/custom-homework-maker-logo.webp' },
  { name: '1 to 5 App', desc: 'Simplified rating system for businesses', url: 'https://www.1to5app.com/', image: '/images/1-to-5-app-logo.webp' },
  { name: 'RapidReportCard', desc: 'Automated educational assessment tool', url: 'https://rapidreportcard.com/', image: '/images/rapid-report-card-logo.webp' },
  { name: 'Risks.io', desc: 'Enterprise risk management platform', url: 'https://www.risks.io/', image: '/images/risks-io-logo.webp' },
  { name: 'SpeedBrain', desc: 'Cognitive enhancement training system', url: 'https://speedbrain.app/', image: '/images/speed-brain-app-logo.webp' },
];

const openSourceFeatured = [
  {
    name: 'Claude PHP SDK',
    desc: 'The most complete PHP client for the Anthropic Claude API — full feature parity with the official Python SDK, including streaming, tool use, extended thinking, vision, batch processing, and structured outputs.',
    url: 'https://github.com/claude-php/Claude-PHP-SDK',
    image: '/images/claude-php-sdk-logo.svg',
    stars: 136,
    lang: 'PHP',
    langColor: '#777bb4',
  },
  {
    name: 'Claude PHP Agent',
    desc: 'A sophisticated PHP framework for building autonomous AI agents with ReAct loops, plan-execute, and reflection strategies. Supports streaming, tool orchestration, multi-provider routing, and Apple Intelligence integration.',
    url: 'https://github.com/claude-php/claude-php-agent',
    image: '/images/claude-php-agent-logo.svg',
    stars: null,
    lang: 'PHP',
    langColor: '#777bb4',
  },
  {
    name: 'Laragentic',
    desc: 'Agentic AI capabilities built for the Laravel ecosystem — bringing autonomous agents, AI-powered workflows, and rich tool orchestration to PHP\'s most popular framework.',
    url: 'https://github.com/laragentic',
    image: '/images/laragentic-logo.svg',
    stars: null,
    lang: 'PHP',
    langColor: '#ef4444',
  },
];

const openSourceRegular = [
  {
    name: 'PHPBot',
    desc: 'CLI AI assistant with 5-tier cost-optimised routing and Apple Intelligence on-device support',
    url: 'https://github.com/dalehurley/phpbot',
    image: '/images/phpbot-logo.svg',
    lang: 'PHP',
  },
  {
    name: 'Cross-Vendor DMF',
    desc: 'Orchestrate Claude, GPT-4, and Gemini in one pipeline with 79% average cost reduction',
    url: 'https://github.com/dalehurley/cross-vendor-dmf',
    image: '/images/cross-vendor-dmf-logo.svg',
    lang: 'Python',
  },
  {
    name: 'Claude PHP SDK Laravel',
    desc: 'Seamless Laravel integration — facades, service provider DI, and config for the Claude PHP SDK',
    url: 'https://github.com/claude-php/Claude-PHP-SDK-Laravel',
    image: '/images/claude-php-sdk-laravel-logo.svg',
    lang: 'PHP',
  },
];
---

<Layout
  title="Dale Hurley - AI-Driven Tech Entrepreneur & Banking Innovation Leader"
  description="AI-driven tech entrepreneur, banking innovation leader, and co-founder of Avenue Bank. Expert in fintech solutions, AI automation, and startup development."
  keywords="Dale Hurley, AI entrepreneur, fintech, banking innovation, Avenue Bank, CreditorWatch, AI automation, LEAP Legal Software, tech entrepreneur, startup founder, Claude PHP SDK, PHP AI"
  ogType="website"
  ogImage="/images/dale-hurley-og.jpg"
>
  <!-- Hero Section -->
  <div class="relative isolate overflow-hidden bg-gradient-to-b from-[#FF750F]/20 via-[#FF750F]/10 to-white dark:from-[#FF750F]/10 dark:via-[#FF750F]/5 dark:to-gray-900 pt-14">
    <div class="mx-auto max-w-7xl px-6 py-32 sm:py-40 lg:px-8">
      <div class="mx-auto max-w-3xl lg:mx-0 lg:grid lg:max-w-none lg:grid-cols-2 lg:gap-x-16 lg:gap-y-8 xl:grid-cols-1 xl:grid-rows-1 xl:gap-x-8">
        <div class="lg:col-span-2 xl:col-auto">
          <h1 class="max-w-3xl text-4xl font-bold tracking-tight text-balance text-gray-900 dark:text-white sm:text-6xl">
            Building the AI future
          </h1>
          <p class="mt-6 text-xl font-semibold text-[#4B0600] dark:text-[#FF750F]">
            AI-Driven Tech Entrepreneur & Banking Innovation Leader
          </p>
          <div class="mt-6 space-y-4">
            {['Co-founded Avenue Bank', 'Founding CTO of CreditorWatch', '$77M+ funding secured', 'Full banking licence (2024)'].map(text => (
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-[#FF750F] flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                <span class="text-gray-700 dark:text-gray-300">{text}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="mt-10 aspect-[16/12] w-full overflow-hidden rounded-xl sm:mt-16 lg:mt-0 lg:max-w-none xl:row-span-2 xl:row-end-2">
          <img
            src="/images/dale-hurley.jpg"
            alt="Dale Hurley"
            class="h-full w-full object-cover object-top"
            loading="eager"
            fetchpriority="high"
            width="600"
            height="450"
          />
        </div>
        <div class="mt-10 lg:mt-0 xl:col-end-1 xl:row-start-1">
          <div class="mt-10 flex items-center gap-x-6">
            <a href="#track-record" class="rounded-lg bg-[#FF750F] px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-orange-500 transition-colors">
              View Track Record
            </a>
            <a href="#contact" class="text-sm font-semibold text-gray-900 dark:text-white hover:text-[#FF750F] transition-colors">
              Get in touch <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Key Stats / Achievements Section -->
  <section class="py-16 bg-[#FF750F]">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-8 sm:grid-cols-4 text-center fade-in-section">
        {[
          { value: '$77M+', label: 'Funding Secured' },
          { value: '20+', label: 'Years Experience' },
          { value: '16+', label: 'Products & Projects' },
          { value: `${posts.length}+`, label: 'Articles Published' },
        ].map(stat => (
          <div>
            <p class="text-4xl font-bold text-white">{stat.value}</p>
            <p class="mt-1 text-sm font-medium text-orange-100">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Track Record Section -->
  <section id="track-record" class="py-24 sm:py-32 bg-[#FDFDFC] dark:bg-gray-800">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center fade-in-section">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl">Proven Track Record</h2>
        <p class="mt-6 text-lg leading-8 text-gray-600 dark:text-gray-300">
          Building successful fintech companies and AI solutions
        </p>
      </div>
      <div class="mt-16 max-w-2xl mx-auto space-y-20">
        {[
          {
            year: '2024–Present',
            title: 'LEAP Legal Software',
            role: 'AI Practice Management Engineering Lead',
            description: 'Created no-code AI agentic platform for legal firms, transforming how legal professionals manage matter profitability.',
            image: '/images/leap-icon.webp',
          },
          {
            year: '2018–2024',
            title: 'Avenue Bank',
            role: 'Co-founder & Executive Leader',
            description: 'Secured $77M+ funding, obtained full banking licence in 2024, and implemented 24-hour processing systems that revolutionised customer experience.',
            image: '/images/avenue-bank-icon.webp',
          },
          {
            year: '2010–2018',
            title: 'CreditorWatch',
            role: 'CTO & Innovation Director',
            description: 'Led technology and product from startup to successful exit, pioneered AI risk score innovation, and implemented user-centric design principles that transformed credit risk assessment.',
            image: '/images/creditorwatch-icon.webp',
          },
        ].map(item => (
          <div class="flex flex-col sm:flex-row gap-8 items-start fade-in-section">
            <div class="flex-shrink-0">
              <img src={item.image} alt={item.title} class="w-16 h-16 rounded-xl object-contain bg-white p-1 shadow" loading="lazy" />
            </div>
            <div>
              <p class="text-sm font-semibold text-[#FF750F] uppercase tracking-wide">{item.year}</p>
              <h3 class="mt-1 text-xl font-bold text-gray-900 dark:text-white">{item.title}</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400 mb-2">{item.role}</p>
              <p class="text-gray-600 dark:text-gray-300">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- AI Solutions Section -->
  <section id="ai-solutions" class="py-24 sm:py-32 bg-gradient-to-br from-[#FF750F]/10 via-[#FF750F]/5 to-white dark:from-[#FF750F]/5 dark:via-gray-900/50 dark:to-gray-900">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl lg:mx-0 fade-in-section">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl">AI-Powered Solutions</h2>
        <p class="mt-6 text-lg leading-8 text-gray-600 dark:text-gray-300">
          I build AI systems that dramatically accelerate business processes
        </p>
      </div>
      <div class="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-8 lg:mx-0 lg:max-w-none lg:grid-cols-3">
        {[
          {
            title: 'Rapid Prototyping',
            description: 'Transform ideas into functional prototypes in days, not months. Validate concepts quickly and iterate based on real user feedback.',
            svgPath: 'M13 10V3L4 14h7v7l9-11h-7z',
          },
          {
            title: 'Intelligent Automation',
            description: 'Implement AI systems that automate complex business processes, reduce operational costs by 40–60%, and eliminate human error.',
            svgPath: 'M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4',
          },
          {
            title: 'Strategic Innovation',
            description: 'Develop AI-first strategies that create sustainable competitive advantages and open new revenue streams.',
            svgPath: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z',
          },
        ].map(item => (
          <div class="flex flex-col bg-white dark:bg-gray-800 rounded-2xl p-8 shadow-sm fade-in-section">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-[#FF750F]">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.svgPath} />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">{item.title}</h3>
            <p class="mt-2 text-gray-600 dark:text-gray-300 text-sm leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Open Source PHP & AI Ecosystem Section -->
  <section id="open-source" class="py-24 sm:py-32 bg-gray-950 dark:bg-gray-950">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">

      <!-- Section header -->
      <div class="mx-auto max-w-2xl lg:mx-0 fade-in-section">
        <div class="flex items-center gap-3 mb-4">
          <span class="inline-flex items-center gap-1.5 rounded-full bg-[#FF750F]/15 px-3 py-1 text-xs font-semibold text-[#FF750F] ring-1 ring-[#FF750F]/30">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 2a8 8 0 100 16A8 8 0 0010 2zm0 14a6 6 0 110-12 6 6 0 010 12zm-1-5a1 1 0 011-1h.01a1 1 0 110 2H10a1 1 0 01-1-1zm0-4a1 1 0 112 0v2a1 1 0 11-2 0V7z" clip-rule="evenodd"/></svg>
            Open Source
          </span>
          <span class="inline-flex items-center rounded-full bg-[#777bb4]/15 px-3 py-1 text-xs font-semibold text-[#a78bfa] ring-1 ring-[#777bb4]/30">PHP Ecosystem</span>
        </div>
        <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">PHP & AI — Open for Everyone</h2>
        <p class="mt-6 text-lg leading-8 text-gray-400">
          I deeply believe PHP deserves world-class AI tooling. These open-source libraries and learning resources are my contribution back to the PHP community — free, MIT-licensed, and built for the real world.
        </p>
      </div>

      <!-- CodeWithPHP community spotlight -->
      <div class="mt-16 fade-in-section">
        <a
          href="https://codewithphp.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="group relative flex flex-col sm:flex-row items-start sm:items-center gap-8 rounded-3xl bg-gradient-to-br from-[#4B0600] via-[#6b0a00] to-[#4B0600] p-8 sm:p-10 ring-1 ring-[#FF750F]/30 hover:ring-[#FF750F]/60 transition-all duration-300 hover:shadow-2xl hover:shadow-[#FF750F]/10 overflow-hidden"
        >
          <!-- Background decoration -->
          <div class="absolute inset-0 opacity-10 pointer-events-none">
            <div class="absolute -top-8 -right-8 w-48 h-48 rounded-full bg-[#FF750F]"></div>
            <div class="absolute -bottom-12 left-1/3 w-64 h-64 rounded-full bg-[#FF750F]"></div>
          </div>

          <!-- Icon -->
          <div class="relative flex-shrink-0 w-24 h-24 rounded-2xl overflow-hidden bg-[#4B0600] ring-2 ring-[#FF750F]/50 shadow-lg shadow-[#FF750F]/20 group-hover:ring-[#FF750F] transition-all">
            <img src="/images/codewithphp-logo.svg" alt="CodeWithPHP" class="w-full h-full object-cover" loading="lazy" />
          </div>

          <!-- Content -->
          <div class="relative flex-1 min-w-0">
            <div class="flex flex-wrap items-center gap-2 mb-2">
              <span class="inline-flex items-center gap-1 rounded-full bg-[#FF750F] px-2.5 py-0.5 text-xs font-bold text-white">
                ★ Community Project
              </span>
              <span class="inline-flex items-center rounded-full bg-white/10 px-2.5 py-0.5 text-xs font-semibold text-orange-200">PHP 8.4</span>
            </div>
            <h3 class="text-2xl font-bold text-white group-hover:text-[#FF750F] transition-colors">CodeWithPHP.com</h3>
            <p class="mt-2 text-orange-100/80 leading-relaxed max-w-2xl">
              A labour of love for the PHP community. Learn modern PHP 8.4 by building real applications from first principles — before touching frameworks. Covers routers, MVC, algorithms, AI/ML integration, and a full Laravel CRM project. Professional standards throughout. Completely free.
            </p>
            <div class="mt-4 flex flex-wrap gap-3 text-sm text-orange-200/70">
              <span class="flex items-center gap-1.5">
                <svg class="w-4 h-4 text-[#FF750F]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                First-principles curriculum
              </span>
              <span class="flex items-center gap-1.5">
                <svg class="w-4 h-4 text-[#FF750F]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                AI/ML integration tracks
              </span>
              <span class="flex items-center gap-1.5">
                <svg class="w-4 h-4 text-[#FF750F]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                Open-source code on GitHub
              </span>
            </div>
          </div>

          <!-- Arrow -->
          <div class="relative flex-shrink-0 hidden sm:flex items-center justify-center w-10 h-10 rounded-full bg-[#FF750F]/20 group-hover:bg-[#FF750F] transition-colors">
            <svg class="w-5 h-5 text-[#FF750F] group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>
          </div>
        </a>
      </div>

      <!-- Featured open source projects -->
      <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 fade-in-section">
        {openSourceFeatured.map(p => (
          <a
            href={p.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex flex-col rounded-2xl bg-gray-900 ring-1 ring-white/10 hover:ring-[#FF750F]/40 transition-all duration-300 hover:shadow-xl hover:shadow-[#FF750F]/5 overflow-hidden"
          >
            <!-- Top accent bar -->
            <div class="h-1 w-full" style={`background-color: ${p.langColor}`}></div>

            <div class="flex flex-col flex-1 p-6">
              <!-- Icon + stars row -->
              <div class="flex items-start justify-between mb-4">
                <div class="w-14 h-14 rounded-xl overflow-hidden bg-gray-800 flex items-center justify-center ring-1 ring-white/10 group-hover:ring-[#FF750F]/30 transition-all">
                  <img src={p.image} alt={p.name} class="w-12 h-12 object-contain" loading="lazy" />
                </div>
                {p.stars && (
                  <span class="flex items-center gap-1 text-sm font-semibold text-yellow-400">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                    {p.stars}
                  </span>
                )}
              </div>

              <!-- Name -->
              <h3 class="text-lg font-bold text-white group-hover:text-[#FF750F] transition-colors">{p.name}</h3>

              <!-- Lang badge -->
              <div class="mt-1 mb-3">
                <span class="inline-flex items-center gap-1.5 text-xs font-medium text-gray-400">
                  <span class="w-2 h-2 rounded-full inline-block" style={`background-color: ${p.langColor}`}></span>
                  {p.lang}
                </span>
              </div>

              <!-- Description -->
              <p class="text-sm text-gray-400 leading-relaxed flex-1">{p.desc}</p>

              <!-- GitHub link -->
              <div class="mt-5 flex items-center gap-2 text-sm font-medium text-[#FF750F] group-hover:gap-3 transition-all">
                <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
                View on GitHub
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- Secondary open source projects -->
      <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-3 fade-in-section">
        {openSourceRegular.map(p => (
          <a
            href={p.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center gap-4 rounded-xl bg-gray-900 p-4 ring-1 ring-white/10 hover:ring-[#FF750F]/40 transition-all duration-200"
          >
            <div class="flex-shrink-0 w-12 h-12 rounded-lg overflow-hidden bg-gray-800 flex items-center justify-center ring-1 ring-white/10">
              <img src={p.image} alt={p.name} class="w-10 h-10 object-contain" loading="lazy" />
            </div>
            <div class="min-w-0 flex-1">
              <p class="text-sm font-semibold text-white group-hover:text-[#FF750F] transition-colors truncate">{p.name}</p>
              <p class="text-xs text-gray-500 mt-0.5 line-clamp-2 leading-relaxed">{p.desc}</p>
            </div>
            <svg class="w-4 h-4 text-gray-600 group-hover:text-[#FF750F] transition-colors flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Commercial Projects Section -->
  <section id="projects" class="py-24 sm:py-32 bg-white dark:bg-gray-800">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center fade-in-section">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl">Products & Ventures</h2>
        <p class="mt-6 text-lg leading-8 text-gray-600 dark:text-gray-300">
          Commercial solutions transforming industries through AI and innovation
        </p>
      </div>
      <div class="mx-auto mt-16 grid max-w-2xl grid-cols-2 gap-x-8 gap-y-10 sm:grid-cols-4 lg:mx-0 lg:max-w-none lg:grid-cols-4 fade-in-section">
        {commercialProjects.map(p => (
          <a href={p.url} target="_blank" rel="noopener noreferrer" class="flex flex-col items-center text-center group">
            <div class="w-16 h-16 mb-3 rounded-xl overflow-hidden bg-gray-100 dark:bg-gray-700 flex items-center justify-center group-hover:shadow-md group-hover:shadow-[#FF750F]/20 transition-all duration-200">
              <img src={p.image} alt={p.name} class="w-12 h-12 object-contain" loading="lazy" />
            </div>
            <p class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-[#FF750F] transition-colors">{p.name}</p>
            <p class="text-xs text-gray-500 dark:text-gray-400 mt-1 line-clamp-2">{p.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Latest Posts Section -->
  {featuredPosts.length > 0 && (
    <section class="py-24 sm:py-32 bg-gray-50 dark:bg-gray-900">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center fade-in-section">
          <h2 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl">Latest Posts</h2>
          <p class="mt-6 text-lg leading-8 text-gray-600 dark:text-gray-300">
            Thoughts on AI, technology, and entrepreneurship
          </p>
        </div>
        <div class="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-8 lg:mx-0 lg:max-w-none lg:grid-cols-3">
          {featuredPosts.map(post => {
            const readingTime = estimateReadingTime(post.body);
            return (
              <a
                href={`/posts/${post.slug}`}
                class="bg-white dark:bg-gray-800 rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow fade-in-section group"
              >
                {post.data.thumbnail && (
                  <div class="aspect-[3/2] overflow-hidden">
                    <img
                      src={post.data.thumbnail.startsWith('/') ? post.data.thumbnail : `/${post.data.thumbnail}`}
                      alt={post.data.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                      loading="lazy"
                    />
                  </div>
                )}
                <div class="p-6">
                  <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2 group-hover:text-[#FF750F] transition-colors">{post.data.title}</h3>
                  {post.data.description && (
                    <p class="text-gray-600 dark:text-gray-400 text-sm line-clamp-3">{post.data.description}</p>
                  )}
                  <div class="mt-4 flex items-center justify-between text-sm text-gray-500 dark:text-gray-400">
                    <p>{post.data.date.toLocaleDateString('en-AU', { year: 'numeric', month: 'short', day: 'numeric' })}</p>
                    <span class="flex items-center gap-1">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      {readingTime} min read
                    </span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
        <div class="text-center mt-12">
          <a
            href="/posts"
            class="inline-flex items-center px-6 py-3 bg-[#FF750F] text-white rounded-lg hover:bg-orange-500 transition-colors font-semibold"
          >
            View All Posts <span class="ml-2">→</span>
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Contact CTA Section -->
