          <a
            href="https://x.com/dalehurley"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 border border-orange-400/40 text-orange-100 rounded-lg hover:bg-white/10 transition-colors font-semibold"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84" />
            </svg>
            Follow on X
          </a>
        </div>
        <div class="mt-8 flex flex-wrap justify-center gap-6 text-sm text-orange-300">
          <a href="https://github.com/dalehurley" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">GitHub</a>
          <a href="https://github.com/claude-php" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">claude-php org</a>
          <a href="/rss.xml" class="hover:text-white transition-colors">RSS Feed</a>
          <a href="/posts" class="hover:text-white transition-colors">Blog</a>
        </div>
      </div>
    </div>
  </section>

