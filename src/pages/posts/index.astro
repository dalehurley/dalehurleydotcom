---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Estimate reading time from raw body (average 200 wpm)
function estimateReadingTime(body: string): number {
  const words = body.trim().split(/\s+/).length;
  return Math.max(1, Math.round(words / 200));
}

// Collect all unique tags for the filter bar
const allTags = [...new Set(posts.flatMap(p => p.data.tags ?? []))].sort();
---

<Layout
  title="Blog Posts - Dale Hurley"
  description="Explore insights on AI, technology, and entrepreneurship from Dale Hurley. Learn about fintech innovation, AI automation, and startup building strategies."
  keywords="Dale Hurley blog, AI insights, fintech blog, technology entrepreneurship, banking innovation, startup advice"
  ogType="website"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Blog",
      "name": "Dale Hurley Blog",
      "description": "Insights on AI, technology, and entrepreneurship",
      "url": "https://dalehurley.com/posts",
      "author": {
        "@type": "Person",
        "name": "Dale Hurley",
        "url": "https://dalehurley.com"
      }
    })} />
  </Fragment>

  <div class="min-h-screen bg-gray-50 dark:bg-gray-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="text-center mb-12">
        <h1 class="text-4xl lg:text-5xl font-bold text-gray-900 dark:text-white mb-4">Blog Posts</h1>
        <p class="text-xl text-gray-600 dark:text-gray-400">Thoughts on AI, technology, and entrepreneurship</p>
        <p class="mt-2 text-sm text-gray-500 dark:text-gray-500">{posts.length} articles</p>
      </div>

      <!-- Tag filter bar: horizontally scrollable single row -->
      {allTags.length > 0 && (
        <div class="mb-10 overflow-x-auto pb-2 -mx-4 px-4 sm:mx-0 sm:px-0">
          <div class="flex gap-2 w-max sm:w-auto sm:flex-wrap sm:justify-center">
            {allTags.map(tag => (
              <a
                href={`/tags/${tag.toLowerCase().replace(/\s+/g, '-')}`}
                class="inline-flex items-center px-3 py-1.5 rounded-full text-sm font-medium whitespace-nowrap bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-200 dark:border-gray-700 hover:bg-orange-50 hover:text-orange-700 hover:border-orange-300 dark:hover:bg-orange-900/20 dark:hover:text-orange-300 transition-colors shadow-sm"
              >
                {tag}
              </a>
            ))}
          </div>
        </div>
      )}

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {posts.length === 0 ? (
          <div class="col-span-full text-center py-12">
            <p class="text-gray-500 dark:text-gray-400 text-lg">No posts found.</p>
          </div>
        ) : posts.map(post => {
          const readingTime = estimateReadingTime(post.body);
          return (
            <a
              href={`/posts/${post.slug}`}
              class="bg-white dark:bg-gray-800 rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow flex flex-col group"
            >
              {post.data.thumbnail && (
                <div class="aspect-[3/2] overflow-hidden">
                  <img
                    src={post.data.thumbnail.startsWith('/') ? post.data.thumbnail : `/${post.data.thumbnail}`}
                    alt={post.data.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                  />
                </div>
              )}
              <div class="p-6 flex flex-col flex-1">
                <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-3 group-hover:text-[#FF750F] transition-colors">{post.data.title}</h2>

                {post.data.description && (
                  <p class="text-gray-600 dark:text-gray-400 mb-4 line-clamp-3 flex-1">{post.data.description}</p>
                )}

                <!-- #9: Reading time in listing -->
                <div class="flex items-center justify-between text-sm text-gray-500 dark:text-gray-400 mt-auto">
                  <time datetime={post.data.date.toISOString()}>
                    {post.data.date.toLocaleDateString('en-AU', { year: 'numeric', month: 'short', day: 'numeric' })}
                  </time>
                  <span class="flex items-center gap-1">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    {readingTime} min read
                  </span>
                </div>

                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2 mt-4" onclick="event.preventDefault()">
                    {post.data.tags.slice(0, 3).map(tag => (
                      <a
                        href={`/tags/${tag.toLowerCase().replace(/\s+/g, '-')}`}
                        class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-orange-100 text-orange-800 dark:bg-orange-900 dark:text-orange-200 hover:bg-orange-200 dark:hover:bg-orange-800 transition-colors"
                        onclick="event.stopPropagation()"
                      >
                        {tag}
                      </a>
                    ))}
                    {post.data.tags.length > 3 && (
                      <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-400">
                        +{post.data.tags.length - 3} more
                      </span>
                    )}
                  </div>
                )}
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </div>
</Layout>
