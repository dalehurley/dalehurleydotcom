---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Waiting Game Example | DaleHurley.com"
  description="An example one-button mini game inspired by ftaip/waiting-game."
  keywords="waiting game, one button game, canvas game, pixel runner"
>
  <main id="main-content" class="min-h-screen bg-gradient-to-b from-slate-950 to-slate-900 text-slate-100 py-16 px-6">
    <div class="mx-auto max-w-4xl">
      <p class="text-sm uppercase tracking-[0.2em] text-orange-300">Example Page</p>
      <h1 class="mt-2 text-4xl font-bold sm:text-5xl">Waiting Game (Runner Demo)</h1>
      <p class="mt-4 text-slate-300 max-w-2xl">
        This page is an example inspired by
        <a class="text-orange-300 underline decoration-orange-500/60 hover:text-orange-200" href="https://github.com/ftaip/waiting-game" target="_blank" rel="noreferrer">ftaip/waiting-game</a>:
        a tiny one-button arcade idea you can play while waiting for long tasks.
      </p>

      <div class="mt-8 rounded-2xl border border-white/10 bg-black/30 p-4 sm:p-6 shadow-2xl shadow-black/40">
        <div id="waiting-game-root"></div>
        <noscript>
          <p class="text-sm text-slate-300">This demo needs JavaScript enabled.</p>
        </noscript>
      </div>
    </div>
  </main>

  <script is:inline type="module">
    const rootEl = document.getElementById('waiting-game-root');

    async function boot() {
      const React = await import('https://esm.sh/react@18.3.1');
      const ReactDOM = await import('https://esm.sh/react-dom@18.3.1/client');
      const WaitingGame = await import('https://esm.sh/react-waiting-game');
      const { useMemo, useState } = React;
      const { WaitingArcade, GAMES, GAME_IDS } = WaitingGame;
      const e = React.createElement;

      function App() {
        const [game, setGame] = useState('jellyfish');
        const [skin, setSkin] = useState(GAMES.jellyfish.defaultSkin);
        const [bestCombo, setBestCombo] = useState(1);
        const [pickups, setPickups] = useState(0);
        const [achievements, setAchievements] = useState([]);

        const skins = useMemo(() => GAMES[game].skins, [game]);

        function switchGame(nextGame) {
          setGame(nextGame);
          setSkin(GAMES[nextGame].defaultSkin);
          setBestCombo(1);
          setPickups(0);
          setAchievements([]);
        }

        function buttonStyle(active) {
          return [
            'rounded-md border px-3 py-1.5 text-sm transition',
            active
              ? 'border-orange-400 bg-orange-500 text-white'
              : 'border-white/20 bg-white/5 text-slate-200 hover:bg-white/10',
          ].join(' ');
        }

        return e('div', { className: 'space-y-4' }, [
          e('div', { className: 'space-y-1', key: 'header' }, [
            e('p', { className: 'text-sm font-semibold text-slate-100', key: 'title' }, 'Built with react-waiting-game'),
            e(
              'p',
              { className: 'text-xs text-slate-400', key: 'subtitle' },
              'Pick a game + skin. One-button controls work with keyboard, click, or touch.',
            ),
          ]),
          e('div', { className: 'flex flex-wrap items-center gap-2', key: 'game-buttons' }, [
            e('span', { className: 'text-xs uppercase tracking-wider text-slate-400', key: 'label' }, 'Game'),
            ...GAME_IDS.map((id) =>
              e(
                'button',
                { type: 'button', className: buttonStyle(game === id), onClick: () => switchGame(id), key: `game-${id}` },
                id,
              ),
            ),
          ]),
          e('div', { className: 'flex flex-wrap items-center gap-2', key: 'skin-buttons' }, [
            e('span', { className: 'text-xs uppercase tracking-wider text-slate-400', key: 'label' }, 'Skin'),
            ...skins.map((id) =>
              e(
                'button',
                { type: 'button', className: buttonStyle(skin === id), onClick: () => setSkin(id), key: `skin-${id}` },
                id,
              ),
            ),
          ]),
          e('div', { className: 'rounded-xl border border-white/10 bg-[#090f1a] p-3', key: 'arcade' }, [
            e(WaitingArcade, {
              game,
              skin,
              width: 900,
              height: 280,
              color: '#f97316',
              persistHighScore: true,
              persistAchievements: true,
              storageKey: 'waiting-arcade:hi:',
              achievementsStorageKey: 'waiting-arcade:ach:',
              onComboChange: (_, m) => setBestCombo((prev) => Math.max(prev, m)),
              onPickup: setPickups,
              onAchievement: (id) => setAchievements((prev) => (prev.includes(id) ? prev : [...prev, id])),
              key: `arcade-${game}-${skin}`,
            }),
          ]),
          e('div', { className: 'text-xs text-slate-300', key: 'stats' }, `Session pickups: ${pickups} · Best combo: x${bestCombo}`),
          achievements.length
            ? e(
                'p',
                { className: 'text-xs text-emerald-300', key: 'achievements' },
                `Achievements this session: ${achievements.join(', ')}`,
              )
            : null,
        ]);
      }

      ReactDOM.createRoot(rootEl).render(e(App));
    }

    boot().catch((error) => {
      console.error(error);
      rootEl.innerHTML = '<p class="text-sm text-rose-300">Unable to load the waiting-game engine right now.</p>';
    });
  </script>
</Layout>
